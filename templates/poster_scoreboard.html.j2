{#-
  Rubric Scoreboard poster · 640px wide, height grows with content.

  Renders from a snapshot dict; see templates/README.md for the JSON schema.
  No cost figures, no raw student feedback, no per-chapter downvote rates
  in the image (locked plan decision #8).
-#}
{% from "_sparkline.html.j2" import sparkline -%}
{%- set ks = kill_switch_breach -%}
{%- set state_color = {
  "red":     {"text": "#b91c1c", "bg": "#fef2f2", "rail": "#dc2626", "dot": "#dc2626"},
  "yellow":  {"text": "#a16207", "bg": "#fefce8", "rail": "#ca8a04", "dot": "#ca8a04"},
  "green":   {"text": "#15803d", "bg": "#f0fdf4", "rail": "#16a34a", "dot": "#16a34a"},
  "neutral": {"text": "#334155", "bg": "#f8fafc", "rail": "#94a3b8", "dot": "#94a3b8"}
} -%}
{%- set dir_glyph = {"up": "▲", "down": "▼", "flat": "·"} -%}
{#- state_glyph removed: dogfood QA #D1, the per-row dot triple-encoded
    state (left rail color + value color already convey it) and rendered a
    red dot next to "n/a" deltas, reading as "this delta is bad". -#}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Rubric Scoreboard · {{ date_iso }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<style>
  html, body { background: #f1f5f9; }
  body { font-family: 'Inter', system-ui, sans-serif; font-feature-settings: "ss01","cv11"; -webkit-font-smoothing: antialiased; color: #0f172a; }
  .mono { font-family: 'IBM Plex Mono', ui-monospace, monospace; font-feature-settings: "tnum","zero"; font-variant-numeric: tabular-nums; }
  .display { font-family: 'Inter', system-ui, sans-serif; font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; }
  .eyebrow { font-family: 'IBM Plex Mono', ui-monospace, monospace; letter-spacing: 0.12em; text-transform: uppercase; font-size: 11px; color: #64748b; }
  .rule { border-top: 1px solid #e2e8f0; }
  .rule-thick { border-top: 2px solid #0f172a; }
  .bar-track { background: #e2e8f0; }
  .bar-fill  { background: #0f172a; }
  /* Print-style page card */
  .poster { width: 640px; }
</style>
</head>
<body class="flex justify-center py-6">
<article class="poster bg-white shadow-sm" role="article" aria-label="Rubric Scoreboard for {{ date_iso }}. {{ headline }}">

  {# ── Masthead ─────────────────────────────────────────────────── #}
  <header class="px-7 pt-6 pb-4">
    <div class="flex items-baseline justify-between">
      <div>
        <div class="eyebrow">Rubric Scoreboard</div>
        <div class="mt-1 mono text-[15px] text-slate-600">{{ date_human }}</div>
      </div>
      <div class="text-right">
        <div class="eyebrow">Sample</div>
        <div class="mono text-[15px] text-slate-900">n={{ n_judged }}</div>
      </div>
    </div>
  </header>

  <div class="px-7"><div class="rule-thick"></div></div>

  {# ── Kill-switch band ─────────────────────────────────────────── #}
  {% if ks %}
  <div class="mx-7 mt-4 mb-3 flex items-center gap-3 bg-red-50 border border-red-200 px-4 py-3" role="alert" aria-label="Kill-switch breached">
    <span aria-hidden="true" class="text-[15px]">🔴</span>
    <span class="mono text-[12px] tracking-widest uppercase text-red-700 font-semibold">Kill-switch breached</span>
  </div>
  {% else %}
  <div class="mx-7 mt-4 mb-3 flex items-center gap-3 bg-slate-50 border border-slate-200 px-4 py-2.5">
    <span aria-hidden="true" class="text-[13px]">·</span>
    <span class="mono text-[11px] tracking-widest uppercase text-slate-500">All metrics within band</span>
  </div>
  {% endif %}

  {# ── Headline ─────────────────────────────────────────────────── #}
  <h1 class="display px-7 pt-2 pb-5 text-[26px] text-slate-900">{{ headline }}</h1>

  <div class="px-7"><div class="rule"></div></div>

  {# ── Scoreboard table ─────────────────────────────────────────── #}
  <section class="px-7 pt-5 pb-2" aria-label="Scoreboard metrics">
    <div class="eyebrow mb-3">Scoreboard</div>
    <div class="divide-y divide-slate-100 border border-slate-200">
      {% for row in scoreboard %}
      {%- set sc = state_color[row.state] -%}
      <div class="grid grid-cols-[200px_1fr_auto] items-center gap-4 px-4 py-3.5 relative">
        <span class="absolute left-0 top-0 bottom-0 w-[3px]" style="background: {{ sc.rail }};" aria-hidden="true"></span>
        <div>
          <div class="text-[12px] font-semibold tracking-wide uppercase text-slate-700">{{ row.label }}</div>
          {% if row.note %}<div class="text-[11px] text-slate-500 mt-0.5">{{ row.note }}</div>{% endif %}
        </div>
        <div class="mono text-[26px] font-semibold text-slate-900 leading-none" aria-label="{{ row.label }} value {{ row.value_text }}">{{ row.value_text }}</div>
        <div class="flex items-center gap-1.5" style="color: {{ sc.text }};">
          <span aria-hidden="true" class="text-[13px]">{{ dir_glyph[row.delta_dir] }}</span>
          <span class="mono text-[12px] font-medium" aria-label="delta {{ row.delta_text }}">{{ row.delta_text }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ── Top driver bars ──────────────────────────────────────────── #}
  {% if top_drivers and top_drivers|length > 0 %}
  <section class="px-7 pt-5 pb-2" aria-label="Top axis by fail rate">
    <div class="eyebrow mb-3">Top axis by fail rate</div>
    <ul class="space-y-2.5">
      {% for d in top_drivers %}
      <li class="grid grid-cols-[34px_1fr_56px] items-center gap-3" aria-label="{{ d.label }} count {{ d.count }}">
        <span class="mono text-[12px] text-slate-500">{% if d.code and d.code != d.label %}{{ d.code }}{% endif %}</span>
        <div>
          <div class="text-[13px] text-slate-800 mb-1">{{ d.label }}</div>
          <div class="bar-track h-1.5 w-full">
            <div class="bar-fill h-1.5" style="width: {{ d.bar_pct }}%;" aria-hidden="true"></div>
          </div>
        </div>
        <span class="mono text-[13px] text-slate-900 text-right">{{ d.count }}×</span>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {# ── Trend sparkline ─────────────────────────────────────────── #}
  {% if trend and trend.spark_series %}
  <section class="px-7 pt-5 pb-6" aria-label="{{ trend.label }}">
    <div class="flex items-center justify-between mb-2">
      <span class="eyebrow">14-day Academic FAIL</span>
      <span class="mono text-[11px] text-slate-500">today highlighted</span>
    </div>
    <div class="flex items-end gap-3">
      <div class="flex-1">
        {{ sparkline(spark_series=trend.spark_series, width=560, height=44, stroke="#0f172a", fill="rgba(15,23,42,0.06)", last_dot=true, label=trend.label) }}
      </div>
      <div class="text-right">
        <div class="mono text-[18px] font-semibold text-slate-900 leading-none">{{ "%.1f"|format(trend.spark_series[-1]) }}%</div>
        <div class="text-[11px] text-slate-500 mt-1">today</div>
      </div>
    </div>
  </section>
  {% endif %}

  <div class="px-7"><div class="rule"></div></div>

  {# ── Brand mark ──────────────────────────────────────────────── #}
  <footer class="px-7 py-4 flex items-center justify-between">
    <div class="eyebrow text-slate-500">{{ brand_mark }}</div>
    <div class="mono text-[10px] text-slate-400">{{ date_iso }}</div>
  </footer>

</article>
</body>
</html>
