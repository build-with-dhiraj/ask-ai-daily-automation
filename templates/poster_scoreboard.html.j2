{#-
  Rubric Scoreboard poster, Variant D (verdict + standings table).

  640px wide, height grows with content. Renders from a snapshot dict;
  see templates/README.md for the JSON schema.

  Locked design specs (DESIGN.md):
  - Cream paper background, off-black ink, brick-red reserved for breach.
  - Hanken Grotesk body + IBM Plex Mono numerals, self-hosted WOFF2.
  - Standings table: metric | yesterday | 14d median | delta.
  - NO side-stripe borders. NO Tailwind CDN. NO Google Fonts CDN.
  - NO emoji in the breach band.

  Renderer passes `fonts_base` as a file:// URI to static/fonts/.
-#}
{%- set ks = kill_switch_breach -%}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Rubric Scoreboard, {{ date_iso }}</title>
<style>
  /* Self-hosted font faces, loaded via file:// at render time. */
  @font-face {
    font-family: 'Hanken Grotesk';
    src: url('{{ fonts_base }}/hanken-grotesk-variable.woff2') format('woff2-variations'),
         url('{{ fonts_base }}/hanken-grotesk-variable.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-400.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-500.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-600.woff2') format('woff2');
    font-weight: 600;
    font-style: normal;
    font-display: block;
  }

  /* OKLCH tokens straight from DESIGN.md. */
  :root {
    --bg-paper:        oklch(0.97 0.005 85);
    --bg-paper-deep:   oklch(0.94 0.008 85);
    --ink-body:        oklch(0.22 0.01 240);
    --ink-muted:       oklch(0.50 0.01 240);
    --ink-faint:       oklch(0.65 0.01 240);
    --breach-brick:    oklch(0.55 0.20 28);
    --breach-brick-bg: oklch(0.95 0.05 28);
    --rule:            oklch(0.88 0.006 85);
    --rule-strong:     oklch(0.22 0.01 240);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--bg-paper); }
  body {
    font-family: 'Hanken Grotesk', ui-sans-serif, 'Helvetica Neue', Arial, sans-serif;
    color: var(--ink-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.4;
    display: flex;
    justify-content: center;
    padding: 24px 0;
  }

  .poster {
    width: 640px;
    background: var(--bg-paper);
  }

  .mono {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-feature-settings: "tnum", "zero";
    font-variant-numeric: tabular-nums;
  }

  .eyebrow {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .px { padding-left: 28px; padding-right: 28px; }

  /* Eyebrow row at top */
  .masthead {
    padding: 28px 28px 12px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .masthead .right { color: var(--ink-body); }

  .rule-strong { border-top: 2px solid var(--rule-strong); }
  .rule        { border-top: 1px solid var(--rule); }

  /* Kill-switch band: brick-red text on faint pink, no border, tight padding. */
  .kill-switch {
    margin: 16px 28px 0;
    padding: 6px 12px;
    background: var(--breach-brick-bg);
    color: var(--breach-brick);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Verdict sentence: display headline. */
  .verdict {
    padding: 20px 28px 24px;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.22;
    letter-spacing: -0.01em;
    color: var(--ink-body);
    text-align: left;
  }

  /* Section eyebrow above the standings table. */
  .section-eyebrow {
    padding: 20px 28px 8px;
  }

  /* Standings table: 4 columns, hairlines between rows. */
  .standings {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 8px;
  }
  .standings th, .standings td {
    padding: 12px 4px;
    border-bottom: 1px solid var(--rule);
    vertical-align: middle;
  }
  .standings th:first-child, .standings td:first-child { padding-left: 28px; }
  .standings th:last-child,  .standings td:last-child  { padding-right: 28px; }
  .standings thead th {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    text-align: right;
    padding-top: 4px;
    padding-bottom: 12px;
    border-bottom-color: var(--rule);
  }
  .standings thead th:first-child { text-align: left; }
  .standings tbody td.metric {
    font-family: 'Hanken Grotesk', ui-sans-serif, sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-body);
    text-align: left;
    width: 38%;
  }
  .standings tbody td.num {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-feature-settings: "tnum", "zero";
    font-variant-numeric: tabular-nums;
    font-size: 14px;
    font-weight: 500;
    text-align: right;
    color: var(--ink-body);
  }
  .standings tbody td.num.muted { color: var(--ink-muted); font-weight: 400; }
  .standings tbody td.delta {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-feature-settings: "tnum", "zero";
    font-variant-numeric: tabular-nums;
    font-size: 14px;
    font-weight: 500;
    text-align: right;
    color: var(--ink-body);
  }
  .standings tbody td.delta.breach { color: var(--breach-brick); }
  .standings tbody tr:last-child td { border-bottom: 1px solid var(--rule); }

  /* Footer */
  .footer {
    padding: 14px 28px 28px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .footer .brand {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .footer .date {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--ink-faint);
    font-feature-settings: "tnum", "zero";
  }
</style>
</head>
<body>
<article class="poster" role="article" aria-label="Rubric Scoreboard for {{ date_iso }}. {{ verdict }}">

  {# Eyebrow row #}
  <div class="masthead">
    <div class="eyebrow">Rubric Scoreboard, {{ date_human }}</div>
    <div class="eyebrow right">Sample n={{ n_judged }}</div>
  </div>

  <div class="px"><div class="rule-strong"></div></div>

  {# Kill-switch band (only on breach) #}
  {% if ks %}
  <div class="kill-switch" role="alert">Kill-switch breached</div>
  {% endif %}

  {# Verdict sentence #}
  <h1 class="verdict">{{ verdict }}</h1>

  <div class="px"><div class="rule"></div></div>

  {# Standings table eyebrow #}
  <div class="section-eyebrow eyebrow">Scoreboard</div>

  {# Standings: 5 rows of metric data #}
  <table class="standings" aria-label="Scoreboard standings">
    <thead>
      <tr>
        <th scope="col">Metric</th>
        <th scope="col">Yesterday</th>
        <th scope="col">14d median</th>
        <th scope="col">Delta</th>
      </tr>
    </thead>
    <tbody>
      {% for row in standings %}
      <tr>
        <td class="metric">{{ row.label }}</td>
        <td class="num">{{ row.yesterday }}</td>
        <td class="num muted">{{ row.median_14d }}</td>
        <td class="delta{% if row.breach %} breach{% endif %}">{{ row.delta }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="px"><div class="rule"></div></div>

  {# Footer #}
  <footer class="footer">
    <div class="brand">Ask AI, daily eval</div>
    <div class="date">{{ date_iso }}</div>
  </footer>

</article>
</body>
</html>
