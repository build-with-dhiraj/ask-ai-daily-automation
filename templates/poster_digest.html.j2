{#-
  Daily Digest poster, Variant D (verdict + 4 insight cards).

  640px wide, height grows with content. Renders from a
  build_digest_poster_input dict; see templates/README.md for the JSON
  schema.

  Distinct from the Scoreboard surface: scoreboard keeps a 5-row
  standings table; digest replaces the standings table with up to 4
  narrative insight cards (claim + evidence + optional cross-signal).

  Locked design specs (DESIGN.md):
  - Cream paper background, off-black ink, brick-red reserved for breach.
  - Hanken Grotesk body + IBM Plex Mono numerals, self-hosted WOFF2.
  - NO side-stripe borders. NO Tailwind CDN. NO Google Fonts CDN.
  - NO separate breach band; breach is carried by the verdict sentence
    only. The brick-red row stripe lives on the scoreboard surface.

  Renderer passes `fonts_base` as a file:// URI to static/fonts/.
-#}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Daily Digest, {{ date_iso }}</title>
<style>
  /* Self-hosted font faces, loaded via file:// at render time. */
  @font-face {
    font-family: 'Hanken Grotesk';
    src: url('{{ fonts_base }}/hanken-grotesk-variable.woff2') format('woff2-variations'),
         url('{{ fonts_base }}/hanken-grotesk-variable.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-400.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-500.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: block;
  }
  @font-face {
    font-family: 'IBM Plex Mono';
    src: url('{{ fonts_base }}/plex-mono-600.woff2') format('woff2');
    font-weight: 600;
    font-style: normal;
    font-display: block;
  }

  /* OKLCH tokens straight from DESIGN.md. */
  :root {
    --bg-paper:        oklch(0.97 0.005 85);
    --bg-paper-deep:   oklch(0.94 0.008 85);
    --ink-body:        oklch(0.22 0.01 240);
    --ink-muted:       oklch(0.50 0.01 240);
    --ink-faint:       oklch(0.65 0.01 240);
    --breach-brick:    oklch(0.55 0.20 28);
    --breach-brick-bg: oklch(0.95 0.05 28);
    --rule:            oklch(0.88 0.006 85);
    --rule-strong:     oklch(0.22 0.01 240);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { background: var(--bg-paper); }
  body {
    background: var(--bg-paper);
    font-family: 'Hanken Grotesk', ui-sans-serif, 'Helvetica Neue', Arial, sans-serif;
    color: var(--ink-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.4;
    /* No flex / no min-height: body sizes to content so full_page
       screenshots and element screenshots both capture only the poster
       without trailing cream void. */
    width: 640px;
  }

  .poster {
    width: 640px;
    background: var(--bg-paper);
  }

  .mono {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-feature-settings: "tnum", "zero";
    font-variant-numeric: tabular-nums;
  }

  .eyebrow {
    font-family: 'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .px { padding-left: 28px; padding-right: 28px; }

  .masthead {
    padding: 28px 28px 12px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .masthead .right { color: var(--ink-body); }

  .rule-strong { border-top: 2px solid var(--rule-strong); }
  .rule        { border-top: 1px solid var(--rule); }

  .verdict {
    padding: 20px 28px 24px;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.22;
    letter-spacing: -0.01em;
    color: var(--ink-body);
    text-align: left;
  }

  /* Insight cards: stacked, hairline rule between each. No card container,
     no rounded corners, no drop shadow. */
  .insights {
    padding: 0;
  }
  .insight-card {
    padding: 18px 28px;
    border-bottom: 1px solid var(--rule);
  }
  .insight-eyebrow {
    padding: 0 0 6px;
  }
  .insight-claim {
    font-family: 'Hanken Grotesk', ui-sans-serif, sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--ink-body);
    margin: 0 0 4px;
  }
  .insight-icon {
    margin-right: 4px;
  }
  .insight-evidence {
    font-family: 'Hanken Grotesk', ui-sans-serif, sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink-body);
    margin: 0 0 4px;
  }
  .insight-context {
    font-family: 'Hanken Grotesk', ui-sans-serif, sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink-muted);
    margin: 0;
  }

  /* Quiet-day fallback: rendered when digest_cards is empty. Plain Hanken
     400 sentence, no italics, no decoration. */
  .quiet-day {
    padding: 18px 28px;
    font-family: 'Hanken Grotesk', ui-sans-serif, sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
  }

  .footer {
    padding: 14px 28px 28px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .footer .brand {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .footer .date {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--ink-faint);
    font-feature-settings: "tnum", "zero";
  }
</style>
</head>
<body>
<article class="poster" role="article" aria-label="Daily Digest for {{ date_iso }}. {{ verdict }}">

  {# Eyebrow row #}
  <div class="masthead">
    {# eyebrow_separator is " · " (mid-dot with surrounding spaces) by default.
       Keep the template seam tight so a missing separator does not produce
       a double-space artifact in the rendered HTML. #}
    <div class="eyebrow">Daily Digest{{ eyebrow_separator | default(' · ') }}{{ date_human }}</div>
    <div class="eyebrow right">{{ digest_eyebrow_right | default("Today's story") }}</div>
  </div>

  <div class="px"><div class="rule-strong"></div></div>

  {# Verdict sentence: carries breach state via wording, no separate band. #}
  <h1 class="verdict">{{ verdict }}</h1>

  <div class="px"><div class="rule"></div></div>

  {# Insight cards: 0..4 narrative cards. Quiet-day path renders a single
     plain sentence so the surface still has body content. #}
  <div class="insights" aria-label="Insight cards">
    {%- if digest_cards %}
      {%- for card in digest_cards %}
      {% include '_insight_card.html.j2' %}
      {%- endfor %}
    {%- else %}
      <div class="quiet-day">No insights worth surfacing today.</div>
    {%- endif %}
  </div>

  {# Footer #}
  <footer class="footer">
    <div class="brand">Ask AI, daily digest</div>
    <div class="date">{{ date_iso }}</div>
  </footer>

</article>
</body>
</html>
